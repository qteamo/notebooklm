{
  "$schema": "https://raw.githubusercontent.com/nicoulaj/tauri-docs/refs/heads/dev/src/tauri-conf-schema.json",
  "productName": "NotebookLM",
  "version": "1.0.0",
  "identifier": "ai.notebooklm.local",
  "plugins": {},
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "NotebookLM - 本地AI知识库",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.openai.com https://api.anthropic.com https://api.deepseek.com https://lite.duckduckgo.com https://wttr.in https://cn.bing.com blob: data:; img-src 'self' data: blob:; font-src 'self'; worker-src 'self' blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
